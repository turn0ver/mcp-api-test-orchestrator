{
  "name": "Petstore API",
  "version": "1.0",
  "description": "Example collection for https://petstore.swagger.io — a sample API for managing pets in a store.",
  "baseUrl": "https://petstore.swagger.io/v2",
  "defaultHeaders": [
    { "key": "Accept", "value": "application/json" }
  ],
  "endpoints": [
    {
      "name": "List Pets",
      "method": "GET",
      "path": "/pet/findByStatus",
      "description": "Finds pets by their status (available, pending, sold).",
      "queryParams": [
        { "key": "status", "value": "available" }
      ],
      "expectedStatus": 200,
      "responseSchema": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["id", "name", "status"],
          "properties": {
            "id": { "type": "integer" },
            "name": { "type": "string" },
            "status": { "type": "string", "enum": ["available", "pending", "sold"] }
          }
        }
      },
      "tags": ["pets", "read"]
    },
    {
      "name": "Get Pet by ID",
      "method": "GET",
      "path": "/pet/{petId}",
      "description": "Returns a single pet by its ID.",
      "pathParams": {
        "petId": 1
      },
      "expectedStatus": 200,
      "responseSchema": {
        "type": "object",
        "required": ["id", "name", "status"],
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "status": { "type": "string", "enum": ["available", "pending", "sold"] }
        }
      },
      "tags": ["pets", "read"]
    },
    {
      "name": "Add a New Pet",
      "method": "POST",
      "path": "/pet",
      "description": "Adds a new pet to the store.",
      "expectedStatus": 200,
      "body": {
        "id": 123,
        "name": "Fluffy",
        "status": "available"
      },
      "responseSchema": {
        "type": "object",
        "required": ["id", "name", "status"],
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "status": { "type": "string", "enum": ["available", "pending", "sold"] }
        }
      },
      "tags": ["pets", "write"]
    },
    {
      "name": "Update an Existing Pet",
      "method": "PUT",
      "path": "/pet",
      "description": "Updates an existing pet in the store.",
      "expectedStatus": 200,
      "body": {
        "id": 123,
        "name": "Fluffy Updated",
        "status": "pending"
      },
      "responseSchema": {
        "type": "object",
        "required": ["id", "name", "status"],
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "status": { "type": "string", "enum": ["available", "pending", "sold"] }
        }
      },
      "tags": ["pets", "write"]
    },
    {
      "name": "Delete Pet",
      "method": "DELETE",
      "path": "/pet/{petId}",
      "description": "Deletes a pet by its ID.",
      "pathParams": {
        "petId": 123
      },
      "expectedStatus": 200,
      "tags": ["pets", "write"]
    },
    {
      "name": "Place an Order",
      "method": "POST",
      "path": "/store/order",
      "description": "Places an order for a pet.",
      "expectedStatus": 200,
      "body": {
        "id": 1,
        "petId": 123,
        "quantity": 2,
        "shipDate": "2026-03-05T12:00:00Z",
        "status": "placed",
        "complete": true
      },
      "responseSchema": {
        "type": "object",
        "required": ["id", "petId", "quantity", "status"],
        "properties": {
          "id": { "type": "integer" },
          "petId": { "type": "integer" },
          "quantity": { "type": "integer" },
          "shipDate": { "type": "string", "format": "date-time" },
          "status": { "type": "string", "enum": ["placed", "approved", "delivered"] },
          "complete": { "type": "boolean" }
        }
      },
      "tags": ["store", "write"]
    },
    {
      "name": "Get Order by ID",
      "method": "GET",
      "path": "/store/order/{orderId}",
      "description": "Finds an order by its ID.",
      "pathParams": {
        "orderId": 1
      },
      "expectedStatus": 200,
      "responseSchema": {
        "type": "object",
        "required": ["id", "petId", "quantity", "status"],
        "properties": {
          "id": { "type": "integer" },
          "petId": { "type": "integer" },
          "quantity": { "type": "integer" },
          "shipDate": { "type": "string", "format": "date-time" },
          "status": { "type": "string", "enum": ["placed", "approved", "delivered"] },
          "complete": { "type": "boolean" }
        }
      },
      "tags": ["store", "read"]
    }
  ]
}
